<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-xl font-bold text-slate-900">Books</h1>
    <p class="text-sm text-slate-400 mt-0.5"><%= @books.count %> total</p>
  </div>
  <%= link_to new_dashboard_book_path, class: "inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-yellow-400 text-slate-900 text-sm font-semibold hover:bg-yellow-500 transition-colors" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
    </svg>
    New Book
  <% end %>
</div>

<div class="bg-white rounded-xl border border-stone-200 overflow-hidden">
  <% if @books.any? %>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-stone-100">
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Title</th>
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Author</th>
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Tags</th>
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Status</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody>
        <% @books.each do |book| %>
          <tr class="border-b border-stone-50 hover:bg-stone-50 transition-colors">
            <td class="px-5 py-3 font-medium text-slate-900"><%= book.name %></td>
            <td class="px-5 py-3 text-slate-500"><%= book.author.name %></td>
            <td class="px-5 py-3">
              <div class="flex flex-wrap gap-1">
                <% book.tags.each do |tag| %>
                  <span class="text-xs px-1.5 py-0.5 rounded bg-yellow-50 text-yellow-700 border border-yellow-200"><%= tag.name %></span>
                <% end %>
              </div>
            </td>
            <td class="px-5 py-3">
              <% if book.available? %>
                <span class="text-xs font-medium text-emerald-600">Available</span>
              <% else %>
                <span class="text-xs font-medium text-orange-500">On Loan</span>
              <% end %>
            </td>
            <td class="px-5 py-3">
              <div class="flex items-center gap-3 justify-end">
                <%= link_to "Edit", edit_dashboard_book_path(book), class: "text-xs font-medium text-slate-600 hover:text-slate-900 transition-colors" %>
                <%= button_to "Delete", dashboard_book_path(book), method: :delete,
                      data: { turbo_confirm: "Delete \"#{book.name}\"?" },
                      class: "text-xs font-medium text-red-500 hover:text-red-700 transition-colors cursor-pointer" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="px-5 py-12 text-sm text-slate-400 text-center">No books yet. <%= link_to "Add one", new_dashboard_book_path, class: "text-yellow-600 font-medium" %></p>
  <% end %>
</div>
