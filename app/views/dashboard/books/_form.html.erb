<%= form_with model: [:dashboard, book], class: "space-y-5" do |f| %>
  <% if book.errors.any? %>
    <div class="p-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">
      <ul class="list-disc pl-4 space-y-0.5">
        <% book.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-xs font-semibold uppercase tracking-wide text-slate-600 mb-1.5" %>
    <%= f.text_field :name,
          class: "w-full px-3 py-2.5 rounded-lg border border-stone-200 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition",
          placeholder: "Book title" %>
  </div>

  <div>
    <%= f.label :author_id, "Author", class: "block text-xs font-semibold uppercase tracking-wide text-slate-600 mb-1.5" %>
    <%= f.select :author_id,
          options_from_collection_for_select(@authors, :id, :name, book.author_id),
          { prompt: "Select an author" },
          class: "w-full px-3 py-2.5 rounded-lg border border-stone-200 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition" %>
  </div>

  <div>
    <p class="block text-xs font-semibold uppercase tracking-wide text-slate-600 mb-2">Tags</p>
    <div class="flex flex-wrap gap-3">
      <% @tags.each do |tag| %>
        <label class="flex items-center gap-2 text-sm text-slate-700 cursor-pointer">
          <%= f.check_box :tag_ids, { multiple: true, checked: book.tags.include?(tag), class: "w-4 h-4 rounded border-stone-300 text-yellow-400 focus:ring-yellow-400" }, tag.id, false %>
          <%= tag.name %>
        </label>
      <% end %>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "px-5 py-2.5 rounded-lg bg-yellow-400 text-slate-900 text-sm font-semibold hover:bg-yellow-500 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", dashboard_books_path, class: "text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
  </div>
<% end %>
