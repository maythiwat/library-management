<%= form_with model: [:dashboard, book], class: "space-y-5" do |f| %>
  <% if book.errors.any? %>
    <div class="p-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">
      <ul class="list-disc pl-4 space-y-0.5">
        <% book.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-xs font-semibold uppercase tracking-wide text-slate-600 mb-1.5" %>
    <%= f.text_field :name,
          class: "w-full px-3 py-2.5 rounded-lg border border-stone-200 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition",
          placeholder: "Book title" %>
  </div>

  <div>
    <%= f.label :thumbnail_url, "Thumbnail URL", class: "block text-xs font-semibold uppercase tracking-wide text-slate-600 mb-1.5" %>
    <div class="flex gap-3 items-start">
      <div class="flex-1">
        <%= f.url_field :thumbnail_url,
              class: "w-full px-3 py-2.5 rounded-lg border border-stone-200 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition",
              placeholder: "https://example.com/cover.jpg" %>
        <p class="text-xs text-slate-400 mt-1">Leave blank to use the default placeholder</p>
      </div>
      <div class="w-14 aspect-[2/3] rounded-lg border border-stone-200 overflow-hidden shrink-0 bg-yellow-50 flex items-center justify-center">
        <% if book.thumbnail_url.present? %>
          <img src="<%= book.thumbnail_url %>" alt="Cover" class="w-full h-full object-cover"
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div style="display:none" class="w-full h-full items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-yellow-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
        <% else %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-yellow-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        <% end %>
      </div>
    </div>
  </div>

  <div>
    <%= f.label :author_id, "Author", class: "block text-xs font-semibold uppercase tracking-wide text-slate-600 mb-1.5" %>
    <%= f.select :author_id,
          options_from_collection_for_select(@authors, :id, :name, book.author_id),
          { prompt: "Select an author" },
          class: "w-full px-3 py-2.5 rounded-lg border border-stone-200 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition" %>
  </div>

  <div>
    <p class="block text-xs font-semibold uppercase tracking-wide text-slate-600 mb-2">Tags</p>
    <div class="flex flex-wrap gap-3">
      <% @tags.each do |tag| %>
        <label class="flex items-center gap-2 text-sm text-slate-700 cursor-pointer">
          <%= f.check_box :tag_ids, { multiple: true, checked: book.tags.include?(tag), class: "w-4 h-4 rounded border-stone-300 text-yellow-400 focus:ring-yellow-400" }, tag.id, false %>
          <%= tag.name %>
        </label>
      <% end %>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "px-5 py-2.5 rounded-lg bg-yellow-400 text-slate-900 text-sm font-semibold hover:bg-yellow-500 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", dashboard_books_path, class: "text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
  </div>
<% end %>
