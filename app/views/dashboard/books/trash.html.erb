<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-xl font-bold text-slate-900">Trash</h1>
    <p class="text-sm text-slate-400 mt-0.5"><%= @deleted_books.count %> deleted book<%= @deleted_books.count == 1 ? "" : "s" %></p>
  </div>
  <%= link_to "← Books", dashboard_books_path, class: "text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
</div>

<div class="bg-white rounded-xl border border-stone-200 overflow-hidden">
  <% if @deleted_books.any? %>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-stone-100">
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Title</th>
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Author</th>
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Deleted</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody>
        <% @deleted_books.each do |book| %>
          <tr class="border-b border-stone-50 hover:bg-stone-50 transition-colors">
            <td class="px-5 py-3 font-medium text-slate-500 line-through"><%= book.name %></td>
            <td class="px-5 py-3 text-slate-400"><%= book.author.name %></td>
            <td class="px-5 py-3 text-slate-400 text-xs"><%= book.deleted_at&.strftime("%d %b %Y, %H:%M") %></td>
            <td class="px-5 py-3 text-right">
              <%= button_to "Restore", restore_dashboard_book_path(book), method: :patch,
                    data: { turbo_confirm: "Restore \"#{book.name}\"?" },
                    class: "text-xs font-semibold text-emerald-600 hover:text-emerald-800 transition-colors cursor-pointer" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="px-5 py-16 text-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-stone-200 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
      <p class="text-sm text-slate-400">Trash is empty</p>
    </div>
  <% end %>
</div>
