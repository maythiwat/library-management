<div class="mb-6">
  <h1 class="text-xl font-bold text-slate-900">Users</h1>
  <p class="text-sm text-slate-400 mt-0.5"><%= @users.count %> registered members
    <% unless can?(:manage, User) %>
      <span class="ml-1 text-xs text-yellow-600 font-medium">(view only)</span>
    <% end %>
  </p>
</div>

<div class="bg-white rounded-xl border border-stone-200 overflow-hidden">
  <% if @users.any? %>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-stone-100">
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Email</th>
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Name</th>
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Roles</th>
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Joined</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="border-b border-stone-50 hover:bg-stone-50 transition-colors">
            <td class="px-5 py-3 text-slate-700 truncate max-w-[200px]"><%= user.email %></td>
            <td class="px-5 py-3 text-slate-500"><%= user.member_profile&.name || "—" %></td>
            <td class="px-5 py-3">
              <div class="flex flex-wrap gap-1">
                <% user.roles.each do |role| %>
                  <span class="text-xs px-1.5 py-0.5 rounded font-semibold
                    <%= role.name == 'admin' ? 'bg-slate-900 text-white' : role.name == 'librarian' ? 'bg-yellow-400 text-slate-900' : 'bg-stone-100 text-slate-600' %>">
                    <%= role.name %>
                  </span>
                <% end %>
                <% if user.roles.empty? %>
                  <span class="text-xs text-slate-400">member</span>
                <% end %>
              </div>
            </td>
            <td class="px-5 py-3 text-slate-400"><%= user.created_at.strftime("%d %b %Y") %></td>
            <td class="px-5 py-3">
              <div class="flex items-center gap-3 justify-end">
                <%= link_to "View", dashboard_user_path(user), class: "text-xs font-medium text-slate-600 hover:text-slate-900 transition-colors" %>
                <% if can?(:manage, User) && user != current_user %>
                  <%= button_to "Delete", dashboard_user_path(user), method: :delete,
                        data: { turbo_confirm: "Delete user #{user.email}? This cannot be undone." },
                        class: "text-xs font-medium text-red-500 hover:text-red-700 transition-colors cursor-pointer" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="px-5 py-12 text-sm text-slate-400 text-center">No users found.</p>
  <% end %>
</div>
