<div class="mb-6">
  <h1 class="text-xl font-bold text-slate-900"><%= @user.member_profile&.name || @user.email %></h1>
  <p class="text-sm text-slate-400 mt-0.5"><%= @user.email %></p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <%# User info + role management %>
  <div class="flex flex-col gap-4">
    <div class="bg-white rounded-xl border border-stone-200 p-5">
      <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Account</p>
      <dl class="space-y-3 text-sm">
        <div>
          <dt class="text-xs text-slate-400">Email</dt>
          <dd class="font-medium text-slate-900 mt-0.5"><%= @user.email %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Name</dt>
          <dd class="font-medium text-slate-900 mt-0.5"><%= @user.member_profile&.name || "—" %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Joined</dt>
          <dd class="font-medium text-slate-900 mt-0.5"><%= @user.created_at.strftime("%d %B %Y") %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Current roles</dt>
          <dd class="mt-1 flex flex-wrap gap-1">
            <% @user.roles.each do |role| %>
              <span class="text-xs px-1.5 py-0.5 rounded font-semibold
                <%= role.name == 'admin' ? 'bg-slate-900 text-white' : role.name == 'librarian' ? 'bg-yellow-400 text-slate-900' : 'bg-stone-100 text-slate-500' %>">
                <%= role.name %>
              </span>
            <% end %>
            <% if @user.roles.empty? %>
              <span class="text-xs text-slate-400">member</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </div>

    <% if can?(:manage, User) && @user != current_user %>
      <div class="bg-white rounded-xl border border-stone-200 p-5">
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Manage Roles</p>
        <%= form_with url: dashboard_user_path(@user), method: :patch, class: "space-y-3" do |f| %>
          <% %w[admin librarian].each do |role| %>
            <label class="flex items-center gap-2.5 text-sm text-slate-700 cursor-pointer">
              <input type="checkbox" name="roles[]" value="<%= role %>"
                     <%= @user.has_role?(role) ? "checked" : "" %>
                     class="w-4 h-4 rounded border-stone-300 text-yellow-400 focus:ring-yellow-400">
              <span class="font-medium capitalize"><%= role %></span>
            </label>
          <% end %>
          <%= f.submit "Save Roles", class: "mt-2 w-full py-2 rounded-lg bg-yellow-400 text-slate-900 text-sm font-semibold hover:bg-yellow-500 transition-colors cursor-pointer" %>
        <% end %>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-xl p-5">
        <p class="text-xs font-semibold uppercase tracking-widest text-red-400 mb-3">Danger Zone</p>
        <%= button_to "Delete User", dashboard_user_path(@user), method: :delete,
              data: { turbo_confirm: "Permanently delete #{@user.email}? This cannot be undone." },
              class: "w-full py-2 rounded-lg border border-red-300 text-red-600 text-sm font-semibold hover:bg-red-100 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <%# Loan history %>
  <div class="lg:col-span-2">
    <div class="bg-white rounded-xl border border-stone-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-stone-100">
        <h2 class="text-sm font-semibold text-slate-900">Loan History <span class="text-slate-400 font-normal">(<%= @loans.count %>)</span></h2>
      </div>
      <% if @loans.any? %>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-stone-100">
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Book</th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Loaned</th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Due</th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Status</th>
            </tr>
          </thead>
          <tbody>
            <% @loans.each do |loan| %>
              <tr class="border-b border-stone-50">
                <td class="px-5 py-3 font-medium text-slate-900 truncate max-w-[180px]"><%= loan.book.name %></td>
                <td class="px-5 py-3 text-slate-400"><%= loan.loaned_at&.strftime("%d %b %Y") %></td>
                <td class="px-5 py-3 text-slate-400"><%= loan.due_at&.strftime("%d %b %Y") %></td>
                <td class="px-5 py-3">
                  <% if loan.returned_at %>
                    <span class="text-xs text-slate-400">Returned</span>
                  <% elsif loan.due_at && loan.due_at < Time.current %>
                    <span class="text-xs font-medium text-red-600">Overdue</span>
                  <% else %>
                    <span class="text-xs font-medium text-emerald-600">Active</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="px-5 py-10 text-sm text-slate-400 text-center">No loan history.</p>
      <% end %>
    </div>
  </div>

</div>

<div class="mt-4">
  <%= link_to "← Back to Users", dashboard_users_path, class: "text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
</div>
