<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-xl font-bold text-slate-900">Loans</h1>
    <p class="text-sm text-slate-400 mt-0.5"><%= @loans.count %> total</p>
  </div>
  <%= link_to new_dashboard_loan_path, class: "inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-yellow-400 text-slate-900 text-sm font-semibold hover:bg-yellow-500 transition-colors" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
    </svg>
    New Loan
  <% end %>
</div>

<div class="bg-white rounded-xl border border-stone-200 overflow-hidden">
  <% if @loans.any? %>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-stone-100">
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Book</th>
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Member</th>
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Loaned</th>
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Due</th>
          <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Status</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody>
        <% @loans.each do |loan| %>
          <% overdue = loan.returned_at.nil? && loan.due_at && loan.due_at < Time.current %>
          <tr class="border-b border-stone-50 hover:bg-stone-50 transition-colors <%= overdue ? 'bg-red-50/40' : '' %>">
            <td class="px-5 py-3 font-medium text-slate-900 max-w-[200px] truncate"><%= loan.book.name %></td>
            <td class="px-5 py-3 text-slate-500 max-w-[150px] truncate"><%= loan.user.member_profile&.name || loan.user.email %></td>
            <td class="px-5 py-3 text-slate-500"><%= loan.loaned_at&.strftime("%d %b %Y") %></td>
            <td class="px-5 py-3 <%= overdue ? 'text-red-600 font-medium' : 'text-slate-500' %>"><%= loan.due_at&.strftime("%d %b %Y") %></td>
            <td class="px-5 py-3">
              <% if loan.returned_at %>
                <span class="text-xs font-medium text-slate-400">Returned <%= loan.returned_at.strftime("%d %b") %></span>
              <% elsif overdue %>
                <span class="text-xs font-medium text-red-600">Overdue</span>
              <% else %>
                <span class="text-xs font-medium text-emerald-600">Active</span>
              <% end %>
            </td>
            <td class="px-5 py-3">
              <div class="flex items-center gap-3 justify-end">
                <% if loan.returned_at.nil? %>
                  <%= button_to "Return", return_book_dashboard_loan_path(loan), method: :patch,
                        data: { turbo_confirm: "Mark this book as returned?" },
                        class: "text-xs font-medium text-yellow-600 hover:text-yellow-800 transition-colors cursor-pointer" %>
                <% end %>
                <%= button_to "Delete", dashboard_loan_path(loan), method: :delete,
                      data: { turbo_confirm: "Delete this loan record?" },
                      class: "text-xs font-medium text-red-500 hover:text-red-700 transition-colors cursor-pointer" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="px-5 py-12 text-sm text-slate-400 text-center">No loans yet. <%= link_to "Create one", new_dashboard_loan_path, class: "text-yellow-600 font-medium" %></p>
  <% end %>
</div>
