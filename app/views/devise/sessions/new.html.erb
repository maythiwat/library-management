<div class="flex min-h-[calc(100vh-10rem)] items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="mb-7">
      <div class="w-10 h-10 rounded-xl bg-yellow-400 flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
      </div>
      <h1 class="text-xl font-bold text-slate-900">Welcome back</h1>
      <p class="text-sm text-slate-400 mt-0.5">Sign in to your library account</p>
    </div>

    <div class="bg-white rounded-xl border border-stone-200 p-6">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, class: "block text-xs font-medium text-slate-700 mb-1.5 uppercase tracking-wide" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                  class: "w-full px-3 py-2.5 rounded-lg border border-stone-200 text-sm text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition",
                  placeholder: "you@example.com" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-xs font-medium text-slate-700 mb-1.5 uppercase tracking-wide" %>
            <%= f.password_field :password, autocomplete: "current-password",
                  class: "w-full px-3 py-2.5 rounded-lg border border-stone-200 text-sm text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition",
                  placeholder: "••••••••" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-stone-300 text-yellow-400 focus:ring-yellow-400" %>
              <%= f.label :remember_me, class: "text-sm text-slate-600" %>
            </div>
          <% end %>

          <%= f.submit "Sign in", class: "w-full py-2.5 px-4 rounded-lg bg-yellow-400 text-slate-900 text-sm font-semibold hover:bg-yellow-500 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:ring-offset-2 transition cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <%= render "devise/shared/links" %>
  </div>
</div>
