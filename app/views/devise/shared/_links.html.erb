<div class="mt-5 flex flex-col items-center gap-2 text-sm text-slate-400">
  <%- if controller_name != 'sessions' %>
    <p>Already have an account? <%= link_to "Sign in", new_session_path(resource_name), class: "text-slate-700 font-medium hover:text-yellow-600 transition-colors" %></p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <p>No account? <%= link_to "Sign up", new_registration_path(resource_name), class: "text-slate-700 font-medium hover:text-yellow-600 transition-colors" %></p>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <p><%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-slate-400 hover:text-slate-600 transition-colors" %></p>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <p><%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "text-slate-400 hover:text-slate-600 transition-colors" %></p>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <p><%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "text-slate-400 hover:text-slate-600 transition-colors" %></p>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <p><%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "text-slate-700 font-medium hover:text-yellow-600 transition-colors cursor-pointer" %></p>
    <% end %>
  <% end %>
</div>
