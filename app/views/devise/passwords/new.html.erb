<div class="flex min-h-[calc(100vh-10rem)] items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="mb-7">
      <div class="w-10 h-10 rounded-xl bg-yellow-400 flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
        </svg>
      </div>
      <h1 class="text-xl font-bold text-slate-900">Reset your password</h1>
      <p class="text-sm text-slate-400 mt-0.5">We'll email you a link to reset it</p>
    </div>

    <div class="bg-white rounded-xl border border-stone-200 p-6">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-4">
          <div>
            <%= f.label :email, class: "block text-xs font-medium text-slate-700 mb-1.5 uppercase tracking-wide" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                  class: "w-full px-3 py-2.5 rounded-lg border border-stone-200 text-sm text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition",
                  placeholder: "you@example.com" %>
          </div>

          <%= f.submit "Send reset instructions", class: "w-full py-2.5 px-4 rounded-lg bg-yellow-400 text-slate-900 text-sm font-semibold hover:bg-yellow-500 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:ring-offset-2 transition cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <%= render "devise/shared/links" %>
  </div>
</div>
