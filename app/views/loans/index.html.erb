<% content_for :title, "My Loans — Library" %>

<div class="mb-6">
  <h1 class="text-xl font-bold text-slate-900">My Loans</h1>
  <p class="mt-0.5 text-sm text-slate-400"><%= current_user.member_profile&.name || current_user.email %></p>
</div>

<%# Active loans %>
<div class="mb-8">
  <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">
    Active <span class="text-slate-300 font-normal">(<%= @active_loans.count %>)</span>
  </h2>

  <% if @active_loans.any? %>
    <div class="bg-white rounded-xl border border-stone-200 overflow-hidden divide-y divide-stone-100">
      <% @active_loans.each do |loan| %>
        <% overdue = loan.due_at < Date.today %>
        <div class="flex items-center gap-4 px-5 py-4 <%= overdue ? 'bg-red-50/50' : '' %>">
          <div class="w-10 h-10 rounded-lg bg-yellow-50 border border-yellow-100 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-yellow-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>

          <div class="flex-1 min-w-0">
            <%= link_to loan.book.name, book_path(loan.book),
                  class: "font-semibold text-slate-900 text-sm hover:text-yellow-600 transition-colors truncate block" %>
            <p class="text-xs text-slate-400 mt-0.5">Loaned <%= loan.loaned_at&.strftime("%d %b %Y") %></p>
          </div>

          <div class="text-right shrink-0">
            <% if overdue %>
              <p class="text-xs font-semibold text-red-600">Overdue</p>
              <p class="text-xs text-red-400 mt-0.5">Was due <%= loan.due_at.strftime("%d %b %Y") %></p>
            <% else %>
              <p class="text-xs text-slate-400">Due</p>
              <p class="text-xs font-semibold text-slate-900 mt-0.5"><%= loan.due_at.strftime("%d %b %Y") %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-xl border border-stone-200 px-5 py-10 text-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-stone-200 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
      </svg>
      <p class="text-sm text-slate-400">No active loans</p>
      <%= link_to "Browse the catalog", books_path, class: "text-sm text-yellow-600 hover:text-yellow-700 font-medium mt-1 inline-block" %>
    </div>
  <% end %>
</div>

<%# Past loans %>
<div>
  <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">
    Returned <span class="text-slate-300 font-normal">(<%= @past_loans.count %>)</span>
  </h2>

  <% if @past_loans.any? %>
    <div class="bg-white rounded-xl border border-stone-200 overflow-hidden divide-y divide-stone-100">
      <% @past_loans.each do |loan| %>
        <div class="flex items-center gap-4 px-5 py-4">
          <div class="w-10 h-10 rounded-lg bg-stone-50 border border-stone-100 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>

          <div class="flex-1 min-w-0">
            <%= link_to loan.book.name, book_path(loan.book),
                  class: "font-medium text-slate-500 text-sm hover:text-slate-700 transition-colors truncate block" %>
            <p class="text-xs text-slate-400 mt-0.5">Loaned <%= loan.loaned_at&.strftime("%d %b %Y") %></p>
          </div>

          <div class="text-right shrink-0">
            <span class="text-xs text-slate-400">Returned</span>
            <p class="text-xs font-medium text-slate-500 mt-0.5"><%= loan.returned_at.strftime("%d %b %Y") %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-slate-400 px-1">No returned loans yet.</p>
  <% end %>
</div>
