<%# Hero %>
<section class="bg-yellow-400 rounded-2xl px-8 py-14 mb-8 text-center">
  <div class="max-w-xl mx-auto">
    <p class="text-xs font-semibold tracking-widest uppercase text-yellow-700 mb-4">Library Management System</p>
    <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
      Your knowledge,<br>organized.
    </h1>
    <p class="text-slate-700 text-base leading-relaxed mb-8">
      Discover, borrow, and manage books with ease. Explore our full catalog of titles across every genre.
    </p>
    <%= form_with url: books_path, method: :get, class: "flex gap-2 mb-6 justify-center" do |f| %>
      <div class="relative flex-1 max-w-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <%= f.search_field :q, placeholder: "Search books or authors…",
              class: "w-full pl-9 pr-4 py-2.5 rounded-xl bg-white/80 border border-slate-900/20 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900/30 focus:border-transparent" %>
      </div>
      <%= f.submit "Search", class: "px-5 py-2.5 rounded-xl bg-slate-900 text-white text-sm font-semibold hover:bg-slate-800 transition-colors cursor-pointer" %>
    <% end %>

    <div class="flex flex-wrap gap-3 justify-center">
      <%= link_to books_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-slate-900 text-white text-sm font-semibold hover:bg-slate-800 transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        Browse Catalog
      <% end %>
      <% unless user_signed_in? %>
        <%= link_to new_user_registration_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-slate-900/30 text-slate-800 text-sm font-semibold hover:bg-yellow-500 transition-colors" do %>
          Get a Library Card
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<%# Stats %>
<section class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-8">
  <% [
    { label: "Total Books",   value: @total_books,     icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" },
    { label: "Available Now", value: @available_books, icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" },
    { label: "Authors",       value: @total_authors,   icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" },
    { label: "Members",       value: @total_members,   icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" },
  ].each do |stat| %>
    <div class="bg-white rounded-xl border border-stone-200 p-5">
      <p class="text-2xl font-bold text-slate-900"><%= stat[:value] %></p>
      <div class="flex items-center gap-1.5 mt-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-yellow-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="<%= stat[:icon] %>" />
        </svg>
        <p class="text-xs text-slate-500 font-medium"><%= stat[:label] %></p>
      </div>
    </div>
  <% end %>
</section>

<%# Recently Added + Side column %>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <%# Recent books %>
  <div class="lg:col-span-2">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold text-slate-900 uppercase tracking-widest">Recently Added</h2>
      <%= link_to "View all →", books_path, class: "text-sm text-yellow-600 font-medium hover:text-yellow-700 transition-colors" %>
    </div>

    <div class="space-y-2">
      <% @recent_books.each do |book| %>
        <%= link_to book_path(book), class: "bg-white rounded-xl border border-stone-200 hover:border-yellow-300 transition-colors p-4 flex items-center gap-4" do %>
          <div class="shrink-0 w-9 h-9 rounded-lg bg-yellow-50 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <p class="font-medium text-slate-900 text-sm truncate"><%= book.name %></p>
            <p class="text-xs text-slate-400 mt-0.5 truncate"><%= book.author.name %></p>
          </div>
          <div class="shrink-0 flex items-center gap-2">
            <% unless book.tags.empty? %>
              <span class="hidden sm:block text-xs px-2 py-0.5 rounded-full bg-yellow-50 text-yellow-700 font-medium border border-yellow-200"><%= book.tags.first.name %></span>
            <% end %>
            <% if book.available? %>
              <span class="text-xs font-medium text-emerald-600">Available</span>
            <% else %>
              <span class="text-xs font-medium text-orange-500">On Loan</span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Side column %>
  <div class="flex flex-col gap-4">
    <% if user_signed_in? %>
      <div class="bg-white rounded-xl border border-stone-200 p-6">
        <div class="w-10 h-10 rounded-full bg-yellow-100 flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <p class="text-xs text-slate-400 font-medium mb-0.5">Signed in as</p>
        <p class="font-semibold text-slate-900 text-sm truncate mb-0.5"><%= current_user.member_profile&.name || "Member" %></p>
        <p class="text-xs text-slate-400 truncate mb-5"><%= current_user.email %></p>
        <%= link_to books_path, class: "block w-full text-center py-2 px-4 rounded-xl bg-yellow-400 text-slate-900 text-sm font-semibold hover:bg-yellow-500 transition-colors" do %>
          Browse All Books
        <% end %>
      </div>
    <% else %>
      <div class="bg-yellow-400 rounded-xl p-6">
        <h3 class="font-bold text-slate-900 text-base mb-2">Join the library</h3>
        <p class="text-slate-700 text-sm leading-relaxed mb-5">Create a free account to borrow books and track your reading history.</p>
        <%= link_to new_user_registration_path, class: "block w-full text-center py-2 px-4 rounded-xl bg-slate-900 text-white text-sm font-semibold hover:bg-slate-800 transition-colors" do %>
          Create Free Account
        <% end %>
        <p class="text-center text-xs text-slate-600 mt-3">
          Already a member? <%= link_to "Sign in", new_user_session_path, class: "text-slate-900 font-semibold hover:underline" %>
        </p>
      </div>
    <% end %>

    <div class="bg-white border border-stone-200 rounded-xl p-6">
      <p class="text-xs font-semibold text-slate-900 uppercase tracking-widest mb-4">Library Hours</p>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-slate-500">Mon – Fri</dt>
          <dd class="font-medium text-slate-900">9:00 – 18:00</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-slate-500">Saturday</dt>
          <dd class="font-medium text-slate-900">10:00 – 16:00</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-slate-500">Sunday</dt>
          <dd class="font-medium text-slate-400">Closed</dd>
        </div>
      </dl>
    </div>
  </div>

</div>
