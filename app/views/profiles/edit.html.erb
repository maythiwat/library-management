<% content_for :title, "Edit Profile — Library" %>

<div class="mb-6">
  <h1 class="text-xl font-bold text-slate-900">Edit Profile</h1>
  <p class="mt-0.5 text-sm text-slate-400">Update your display name</p>
</div>

<div class="max-w-md">
  <div class="bg-white rounded-xl border border-stone-200 p-6">
    <%= form_with model: @profile, url: profile_path, method: :patch, class: "space-y-5" do |f| %>
      <% if @profile.errors.any? %>
        <div class="p-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">
          <ul class="list-disc pl-4 space-y-0.5">
            <% @profile.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, class: "block text-xs font-semibold uppercase tracking-wide text-slate-600 mb-1.5" %>
        <%= f.text_field :name,
              class: "w-full px-3 py-2.5 rounded-lg border border-stone-200 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition",
              placeholder: "Your full name" %>
      </div>

      <div>
        <label class="block text-xs font-semibold uppercase tracking-wide text-slate-600 mb-1.5">Email</label>
        <p class="px-3 py-2.5 rounded-lg bg-stone-50 border border-stone-200 text-sm text-slate-400"><%= current_user.email %></p>
        <p class="text-xs text-slate-400 mt-1">Email cannot be changed here</p>
      </div>

      <div class="flex items-center gap-3 pt-1">
        <%= f.submit "Save Changes", class: "px-5 py-2.5 rounded-lg bg-yellow-400 text-slate-900 text-sm font-semibold hover:bg-yellow-500 transition-colors cursor-pointer" %>
        <%= link_to "Cancel", profile_path, class: "text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
