<% content_for :title, "My Profile — Library" %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-xl font-bold text-slate-900">My Profile</h1>
    <p class="mt-0.5 text-sm text-slate-400"><%= current_user.email %></p>
  </div>
  <%= link_to "Edit Profile", edit_profile_path, class: "px-4 py-2 rounded-lg bg-yellow-400 text-slate-900 text-sm font-semibold hover:bg-yellow-500 transition-colors" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <%# Account info %>
  <div class="flex flex-col gap-4">
    <div class="bg-white rounded-xl border border-stone-200 p-6">
      <div class="w-12 h-12 rounded-full bg-yellow-100 flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </div>
      <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Account</p>
      <dl class="space-y-3 text-sm">
        <div>
          <dt class="text-xs text-slate-400">Name</dt>
          <dd class="font-medium text-slate-900 mt-0.5"><%= @profile.name.presence || "—" %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Email</dt>
          <dd class="font-medium text-slate-900 mt-0.5 break-all"><%= current_user.email %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Member since</dt>
          <dd class="font-medium text-slate-900 mt-0.5"><%= current_user.created_at.strftime("%d %B %Y") %></dd>
        </div>
      </dl>
    </div>

    <div class="bg-white rounded-xl border border-stone-200 p-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Loan Summary</p>
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-stone-50 rounded-lg p-3 text-center">
          <p class="text-2xl font-bold text-slate-900"><%= @active_loans.count %></p>
          <p class="text-xs text-slate-400 mt-0.5">Active</p>
        </div>
        <div class="bg-stone-50 rounded-lg p-3 text-center">
          <p class="text-2xl font-bold text-slate-900"><%= @total_loans %></p>
          <p class="text-xs text-slate-400 mt-0.5">All time</p>
        </div>
      </div>
      <div class="mt-3">
        <div class="flex items-center justify-between text-xs text-slate-400 mb-1.5">
          <span>Loan slots used</span>
          <span><%= @active_loans.count %> / 3</span>
        </div>
        <div class="w-full bg-stone-100 rounded-full h-1.5">
          <div class="bg-yellow-400 h-1.5 rounded-full transition-all" style="width: <%= (@active_loans.count / 3.0 * 100).round %>%"></div>
        </div>
      </div>
    </div>
  </div>

  <%# Active loans %>
  <div class="lg:col-span-2">
    <div class="bg-white rounded-xl border border-stone-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-stone-100 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-slate-900">Active Loans</h2>
        <%= link_to "View all loans →", loans_path, class: "text-xs text-yellow-600 hover:text-yellow-700 font-medium" %>
      </div>

      <% if @active_loans.any? %>
        <div class="divide-y divide-stone-100">
          <% @active_loans.each do |loan| %>
            <% overdue = loan.due_at < Date.today %>
            <div class="flex items-center gap-4 px-5 py-4 <%= overdue ? 'bg-red-50/40' : '' %>">
              <div class="w-9 h-9 rounded-lg bg-yellow-50 border border-yellow-100 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <%= link_to loan.book.name, book_path(loan.book),
                      class: "font-medium text-slate-900 text-sm hover:text-yellow-600 transition-colors truncate block" %>
                <p class="text-xs text-slate-400 mt-0.5">Loaned <%= loan.loaned_at&.strftime("%d %b %Y") %></p>
              </div>
              <div class="text-right shrink-0">
                <% if overdue %>
                  <span class="text-xs font-semibold text-red-600">Overdue</span>
                  <p class="text-xs text-red-400 mt-0.5"><%= loan.due_at.strftime("%d %b %Y") %></p>
                <% else %>
                  <span class="text-xs text-slate-400">Due</span>
                  <p class="text-xs font-semibold text-slate-900 mt-0.5"><%= loan.due_at.strftime("%d %b %Y") %></p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="px-5 py-10 text-center">
          <p class="text-sm text-slate-400">No active loans</p>
          <%= link_to "Browse catalog", books_path, class: "text-sm text-yellow-600 hover:text-yellow-700 font-medium mt-1 inline-block" %>
        </div>
      <% end %>
    </div>
  </div>

</div>
