<div class="mb-6">
  <h1 class="text-xl font-bold text-slate-900">Book Catalog</h1>
  <p class="mt-0.5 text-sm text-slate-400"><%= @books.count %> books in the library</p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
  <% @books.each do |book| %>
    <div class="group bg-white rounded-xl border border-stone-200 hover:border-yellow-300 transition-colors flex flex-col overflow-hidden">
      <div class="bg-yellow-50 flex items-center justify-center h-32 shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-yellow-200 group-hover:text-yellow-300 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
      </div>

      <div class="p-4 flex flex-col flex-1 gap-3">
        <div class="flex items-start justify-between gap-2">
          <div class="min-w-0">
            <p class="font-semibold text-slate-900 text-sm leading-snug line-clamp-2"><%= book.name %></p>
            <p class="text-xs text-slate-400 mt-0.5 truncate"><%= book.author.name %></p>
          </div>
          <% if book.available? %>
            <span class="shrink-0 text-xs font-medium text-emerald-600 mt-0.5">Available</span>
          <% else %>
            <span class="shrink-0 text-xs font-medium text-orange-500 mt-0.5">On Loan</span>
          <% end %>
        </div>

        <% unless book.tags.empty? %>
          <div class="flex flex-wrap gap-1.5 mt-auto">
            <% book.tags.each do |tag| %>
              <span class="text-xs px-2 py-0.5 rounded-full bg-yellow-50 text-yellow-700 border border-yellow-200 font-medium"><%= tag.name %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<% if @books.empty? %>
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-stone-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
    </svg>
    <p class="text-slate-500 font-medium text-sm">No books found</p>
    <p class="text-xs text-slate-400 mt-1">The catalog is empty.</p>
  </div>
<% end %>
