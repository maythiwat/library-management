<div class="mb-6 flex flex-col sm:flex-row sm:items-end gap-4">
  <div class="flex-1">
    <h1 class="text-xl font-bold text-slate-900">Book Catalog</h1>
    <p class="mt-0.5 text-sm text-slate-400">
      <% if @query.present? %>
        <%= @books.count %> result<%= @books.count == 1 ? "" : "s" %> for "<%= @query %>"
      <% else %>
        <%= @books.count %> books in the library
      <% end %>
    </p>
  </div>

  <%= form_with url: books_path, method: :get, class: "flex gap-2" do |f| %>
    <div class="relative">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <%= f.search_field :q, value: @query, placeholder: "Search books or authors…",
            class: "pl-9 pr-4 py-2 rounded-lg border border-stone-200 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent w-56" %>
    </div>
    <% if @query.present? %>
      <%= link_to "Clear", books_path, class: "px-3 py-2 rounded-lg border border-stone-200 text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
    <% end %>
  <% end %>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
  <% @books.each do |book| %>
    <%= link_to book_path(book), class: "group bg-white rounded-xl border border-stone-200 hover:border-yellow-300 transition-colors flex flex-col overflow-hidden" do %>
      <div class="relative h-32 shrink-0 overflow-hidden <%= book.thumbnail_url.present? ? '' : 'bg-yellow-50' %> flex items-center justify-center">
        <% if book.thumbnail_url.present? %>
          <img src="<%= book.thumbnail_url %>" alt="" class="absolute inset-0 w-full h-full object-cover blur-lg scale-110 opacity-60">
          <img src="<%= book.thumbnail_url %>" alt="<%= book.name %>" class="relative h-full w-auto object-cover drop-shadow-md"
               onerror="this.closest('.relative').classList.add('bg-yellow-50');this.style.display='none';this.previousElementSibling.style.display='none';this.nextElementSibling.style.display='block'">
          <svg style="display:none" xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-yellow-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        <% else %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-yellow-200 group-hover:text-yellow-300 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        <% end %>
      </div>

      <div class="p-4 flex flex-col flex-1 gap-3">
        <div class="flex items-start justify-between gap-2">
          <div class="min-w-0">
            <p class="font-semibold text-slate-900 text-sm leading-snug line-clamp-2"><%= book.name %></p>
            <p class="text-xs text-slate-400 mt-0.5 truncate"><%= book.author.name %></p>
          </div>
          <% if book.available? %>
            <span class="shrink-0 text-xs font-medium text-emerald-600 mt-0.5">Available</span>
          <% else %>
            <span class="shrink-0 text-xs font-medium text-orange-500 mt-0.5">On Loan</span>
          <% end %>
        </div>

        <% unless book.tags.empty? %>
          <div class="flex flex-wrap gap-1.5 mt-auto">
            <% book.tags.each do |tag| %>
              <span class="text-xs px-2 py-0.5 rounded-full bg-yellow-50 text-yellow-700 border border-yellow-200 font-medium"><%= tag.name %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>

<% if @books.empty? %>
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-stone-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
    </svg>
    <p class="text-slate-500 font-medium text-sm">No books found</p>
    <p class="text-xs text-slate-400 mt-1">The catalog is empty.</p>
  </div>
<% end %>
