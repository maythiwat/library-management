<% content_for :title, "#{@book.name} — Library" %>

<div class="mb-4">
  <%= link_to "← Back to Catalog", books_path, class: "text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <%# Book cover + loan action %>
  <div class="flex flex-col gap-4">
    <div class="bg-yellow-50 rounded-xl border border-stone-200 flex items-center justify-center h-52">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20 text-yellow-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
    </div>

    <div class="bg-white rounded-xl border border-stone-200 p-5">
      <% if @book.available? %>
        <div class="flex items-center gap-2 mb-4">
          <span class="w-2 h-2 rounded-full bg-emerald-400 inline-block"></span>
          <span class="text-sm font-medium text-emerald-600">Available to loan</span>
        </div>

        <% if user_signed_in? %>
          <% if @user_active_loan %>
            <div class="py-2.5 rounded-lg bg-yellow-50 border border-yellow-200 text-center text-sm font-semibold text-yellow-700">
              You have this book
            </div>
            <p class="text-xs text-slate-400 text-center mt-2">Due <%= @user_active_loan.due_at.strftime("%d %B %Y") %></p>
          <% elsif @user_active_count >= 3 %>
            <div class="py-2.5 rounded-lg bg-stone-100 text-center text-sm font-medium text-slate-500">
              Loan limit reached
            </div>
            <p class="text-xs text-slate-400 text-center mt-2">Return a book to loan another (max 3)</p>
          <% else %>
            <%= button_to book_loans_path(@book), method: :post,
                  class: "w-full py-2.5 rounded-lg bg-yellow-400 text-slate-900 text-sm font-semibold hover:bg-yellow-500 transition-colors cursor-pointer" do %>
              Loan this Book
            <% end %>
            <p class="text-xs text-slate-400 text-center mt-2">7-day loan period · <%= 3 - @user_active_count %> slot<%= (3 - @user_active_count) == 1 ? "" : "s" %> remaining</p>
          <% end %>
        <% else %>
          <%= link_to new_user_session_path, class: "block w-full py-2.5 rounded-lg bg-yellow-400 text-slate-900 text-sm font-semibold hover:bg-yellow-500 transition-colors text-center" do %>
            Sign in to Loan
          <% end %>
          <p class="text-xs text-slate-400 text-center mt-2">Library card required</p>
        <% end %>

      <% else %>
        <div class="flex items-center gap-2 mb-4">
          <span class="w-2 h-2 rounded-full bg-orange-400 inline-block"></span>
          <span class="text-sm font-medium text-orange-500">Currently on loan</span>
        </div>
        <% if @active_loan&.due_at %>
          <p class="text-xs text-slate-400">Expected return by <%= @active_loan.due_at.strftime("%d %B %Y") %></p>
        <% end %>
        <div class="mt-4 py-2.5 rounded-lg bg-stone-100 text-center text-sm text-slate-400 font-medium">
          Unavailable
        </div>
      <% end %>
    </div>
  </div>

  <%# Book details %>
  <div class="lg:col-span-2 flex flex-col gap-4">
    <div class="bg-white rounded-xl border border-stone-200 p-6">
      <h1 class="text-2xl font-bold text-slate-900 leading-snug"><%= @book.name %></h1>
      <p class="text-slate-500 mt-1">by <span class="font-medium text-slate-700"><%= @book.author.name %></span></p>

      <% unless @book.tags.empty? %>
        <div class="flex flex-wrap gap-1.5 mt-4">
          <% @book.tags.each do |tag| %>
            <span class="text-xs px-2.5 py-1 rounded-full bg-yellow-50 text-yellow-700 border border-yellow-200 font-medium"><%= tag.name %></span>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="bg-white rounded-xl border border-stone-200 p-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Loan Information</p>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between">
          <dt class="text-slate-400">Loan period</dt>
          <dd class="font-medium text-slate-900">7 days</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-slate-400">Status</dt>
          <dd>
            <% if @book.available? %>
              <span class="font-medium text-emerald-600">Available</span>
            <% else %>
              <span class="font-medium text-orange-500">On Loan</span>
            <% end %>
          </dd>
        </div>
        <% if !@book.available? && @active_loan&.due_at %>
          <div class="flex justify-between">
            <dt class="text-slate-400">Expected return</dt>
            <dd class="font-medium text-slate-900"><%= @active_loan.due_at.strftime("%d %B %Y") %></dd>
          </div>
        <% end %>
        <% if @user_active_loan %>
          <div class="flex justify-between">
            <dt class="text-slate-400">Your due date</dt>
            <dd class="font-medium text-slate-900"><%= @user_active_loan.due_at.strftime("%d %B %Y") %></dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

</div>
