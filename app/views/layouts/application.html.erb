<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Library" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Library">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen bg-stone-50 text-slate-900 antialiased">

    <nav class="bg-white border-b border-stone-200" data-controller="toggle">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">

          <%# Logo %>
          <a href="/" class="flex items-center gap-2 font-bold text-base tracking-tight text-slate-900 hover:text-yellow-600 transition-colors shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            Library
          </a>

          <%# Desktop nav links %>
          <div class="hidden md:flex items-center gap-6 ml-8">
            <% if user_signed_in? %>
              <a href="<%= books_path %>" class="text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors">Books</a>
              <a href="<%= loans_path %>" class="text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors">My Loans</a>
              <% if current_user.has_role?(:admin) || current_user.has_role?(:librarian) %>
                <a href="<%= dashboard_root_path %>" class="text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors">Dashboard</a>
              <% end %>
            <% else %>
              <a href="<%= books_path %>" class="text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors">Books</a>
            <% end %>
          </div>

          <%# Desktop right side %>
          <div class="hidden md:flex items-center gap-2 ml-auto">
            <% if user_signed_in? %>
              <%= link_to profile_path, class: "flex items-center gap-2 px-3 py-1.5 rounded-lg text-slate-600 hover:bg-stone-100 transition-colors" do %>
                <div class="w-6 h-6 rounded-full bg-yellow-100 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
                <span class="text-sm font-medium"><%= current_user.member_profile&.name&.split&.first || "Profile" %></span>
              <% end %>
              <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                    class: "text-sm font-medium px-3 py-1.5 rounded-lg text-slate-600 hover:bg-stone-100 transition-colors cursor-pointer" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path,
                    class: "text-sm font-medium px-3 py-1.5 rounded-lg text-slate-600 hover:bg-stone-100 transition-colors" %>
              <%= link_to "Sign up", new_user_registration_path,
                    class: "text-sm font-medium px-3 py-1.5 rounded-lg bg-yellow-400 text-slate-900 hover:bg-yellow-500 transition-colors" %>
            <% end %>
          </div>

          <%# Mobile hamburger %>
          <button data-action="toggle#toggle" class="md:hidden p-2 rounded-lg text-slate-500 hover:bg-stone-100 transition-colors ml-auto">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>

        </div>
      </div>

      <%# Mobile menu %>
      <div class="hidden md:hidden border-t border-stone-100" data-toggle-target="menu">
        <div class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-1">
          <% if user_signed_in? %>
            <div class="flex items-center gap-3 px-3 py-2 mb-1">
              <div class="w-7 h-7 rounded-full bg-yellow-100 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <span class="text-sm text-slate-500 truncate"><%= current_user.member_profile&.name || current_user.email %></span>
            </div>
            <a href="<%= books_path %>" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-700 hover:bg-stone-100 transition-colors">Books</a>
            <a href="<%= loans_path %>" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-700 hover:bg-stone-100 transition-colors">My Loans</a>
            <a href="<%= profile_path %>" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-700 hover:bg-stone-100 transition-colors">My Profile</a>
            <% if current_user.has_role?(:admin) || current_user.has_role?(:librarian) %>
              <a href="<%= dashboard_root_path %>" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-700 hover:bg-stone-100 transition-colors">Dashboard</a>
            <% end %>
            <div class="border-t border-stone-100 mt-1 pt-1">
              <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                    class: "w-full text-left px-3 py-2 rounded-lg text-sm font-medium text-slate-600 hover:bg-stone-100 transition-colors cursor-pointer" %>
            </div>
          <% else %>
            <a href="<%= books_path %>" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-700 hover:bg-stone-100 transition-colors">Books</a>
            <div class="border-t border-stone-100 mt-1 pt-1 flex flex-col gap-1">
              <a href="<%= new_user_session_path %>" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-600 hover:bg-stone-100 transition-colors">Sign in</a>
              <a href="<%= new_user_registration_path %>" class="px-3 py-2 rounded-lg text-sm font-semibold bg-yellow-400 text-slate-900 hover:bg-yellow-500 transition-colors text-center">Sign up</a>
            </div>
          <% end %>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
        <div class="flex items-center gap-3 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm" data-turbo-temporary>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <%= notice %>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
        <div class="flex items-center gap-3 p-4 rounded-xl bg-red-50 border border-red-200 text-red-800 text-sm" data-turbo-temporary>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

  </body>
</html>
